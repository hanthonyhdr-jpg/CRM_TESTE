# Variáveis de ambiente padrão para desenvolvimento
# Copie este arquivo para .env e configure conforme necessário

# ============================================================
# FastAPI
# ============================================================
FASTAPI_ENV=development
DEBUG=True
APP_NAME="CRM Comunicação Visual"
APP_VERSION="1.0.0"

# ============================================================
# Banco de Dados
# ============================================================
DATABASE_URL=sqlite:///./backend/database.db

# ============================================================
# Segurança
# ============================================================
SECRET_KEY=sua_chave_secreta_super_complexa_aqui_mude_em_producao
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=8

# ============================================================
# CORS
# ============================================================
FRONTEND_URL=http://localhost:8001
ALLOWED_ORIGINS=http://localhost:8001,http://localhost:8000

# ============================================================
# Servidor
# ============================================================
HOST=0.0.0.0
PORT=8000
RELOAD=true

# ============================================================
# Email (opcional, para notificações futuras)
# ============================================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_app

# ============================================================
# IA - Anthropic (opcional)
# ============================================================
ANTHROPIC_API_KEY=sk-xxx-yyy-zzz

# ============================================================
# CEP API
# ============================================================
CEPAPI_URL=https://viacep.com.br/ws

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=INFO
